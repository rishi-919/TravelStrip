<% layout("/layouts/boilerplate") -%>
<body>

   <div class="container py-5">

  <div class="row justify-content-center">

    <div class="col-lg-10">

      <!-- Horizontal Card -->
      <div 
        class="card border-0 shadow rounded-4 overflow-hidden"
        style="
          transition: 0.4s ease;
        "

        onmouseover="
          this.style.transform='scale(1.01)';
          this.style.boxShadow='0 1rem 3rem rgba(0,0,0,.15)';
        "

        onmouseout="
          this.style.transform='scale(1)';
          this.style.boxShadow='';
        "
      >

        <div class="row g-0">

          <!-- Image -->
          <div class="col-md-5">

            <img 
              src="<%= listing.image.url%>"
              class="img-fluid h-100 w-100"
              style="
                object-fit: cover;
                min-height: 100%;
              "
              alt="Listing Image"
            >

          </div>

          <!-- Content -->
          <div class="col-md-7">

            <div class="card-body p-4 d-flex flex-column h-100">

              <!-- Title + Price -->
              <div class="d-flex justify-content-between align-items-start mb-2">

                <h3 class="fw-bold">
                  <%= listing.title %>
                </h3>

                <span class="badge bg-danger fs-6 px-3 py-2">
                  ₹ <%= listing.price.toLocaleString("en-IN") %>
                </span>

              </div>

              <!-- Owner -->
              <p class="text-muted mb-3">

                Hosted by 
                <span class="fw-semibold text-dark">
                  <%= listing.owner.username %>
                </span>

              </p>

              <!-- Description -->
              <p class="text-secondary mb-4">
                <%= listing.description %>
              </p>

              <!-- Location -->
              <div class="mb-4">

                <p class="mb-2">
                  <span class="fw-bold">Location:</span>
                  <%= listing.location %>
                </p>

                <p class="mb-0">
                  <span class="fw-bold">Country:</span>
                  <%= listing.country %>
                </p>

              </div>
          <% if (isOwner) { %>
           
              
              <!-- Buttons -->
              <div class="mt-auto d-flex gap-2">

                <!-- Edit -->
                <form 
                  method="get"
                  action="/listings/<%= listing._id %>/edit"
                >
                
                  <button 
                    type="submit"
                    class="btn btn-dark rounded-pill px-4"
                  >
                    Edit
                  </button>
                
                </form>
             
                <!-- Delete -->
                <form 
                  method="get"
                  action="/listings/<%= listing._id %>/delete"
                >

                  <button 
                    type="submit"
                    class="btn btn-danger rounded-pill px-4"
                  >
                    Delete
                  </button>
                  
                </form>
             
              </div>
           <% } %>
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

</div>
        <hr>
      
      <div class="col-8 offset-3 mt-3">
    <h4>Leave a review</h4>

 <form 
    action="/listings/<%= listing._id %>/reviews" 
    method="POST" 
    novalidate 
    class="needs-validation"
>

        <div>

            <div>
                
                 <fieldset class="starability-slot">
  <legend>Rating:</legend>
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>

            </div>
            
            <div>
                <label for="comment"></label>

                <textarea
                    name="review[comment]"
                    id="comment"
                    placeholder="Comments"
                    class="form-control" required
                ></textarea>
              <div class="invalid-feedback">
    Please write some message
</div>

                <button
                    type="submit"
                    class="btn btn-outline-danger"
                    style="margin: 20px;"
                >
                    Submit
                </button>

            </div>

        </div>

    </form>

</div>

<hr>
  <% if (listing.reviews.length>0){ %>

<h3 class="offset-2">All Reviews</h3>

  <% } %>
<% for(let review of listing.reviews){ %>

    <div class="card mb-3 offset-1" style="width: 14rem; display: inline-block;">

         <div class="card-body">
          <h5>@<%= review.author.username %> </h5>
               <b>
                <p class="starability-result card-text" data-rating="<%= review.rating %>">

                </p></b> 

           <p class="mb-0"><%= review.comment %>  
            </p>
            
           <form 
  method="POST"
  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
  class="d-inline"
>
  

  <button 
    type="submit" 
    class="btn btn-secondary btn-sm"
  >
    Delete
  </button>
 
</form>

        </div>

    </div>

<% } %>
</body>
